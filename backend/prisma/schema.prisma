// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id                 Int      @id @default(autoincrement())
  carrier            String
  planName           String   @map("plan_name")
  networkType        String   @map("network_type")
  baseFee            Int      @map("base_fee")
  dataAllowanceGb    Float    @map("data_allowance_gb")
  voiceAllowanceMin  Int      @map("voice_allowance_min")
  rawPlanDescription String   @map("raw_plan_description") @db.Text
  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz

  @@map("plans")
}

model InputSession {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  createdAt DateTime    @default(now()) @db.Timestamptz
  updatedAt DateTime    @updatedAt @db.Timestamptz
  
  userPlan   UserPlan?
  userDemand UserDemand?
  
  @@map("input_sessions")
}

model UserPlan {
  inputId            String       @id @map("input_id") @db.Uuid
  session            InputSession @relation(fields: [inputId], references: [id], onDelete: Cascade)
  carrier            String
  planName           String       @map("plan_name")
  networkType        String       @map("network_type")
  baseFee            Int          @map("base_fee")
  dataAllowanceGb    Float        @map("data_allowance_gb")
  voiceAllowanceMin  Int          @map("voice_allowance_min")
  createdAt          DateTime     @default(now()) @db.Timestamptz
  updatedAt          DateTime     @updatedAt @db.Timestamptz

  @@map("user_plans")
}

model UserDemand {
  inputId              String       @id @map("input_id") @db.Uuid
  session              InputSession @relation(fields: [inputId], references: [id], onDelete: Cascade)
  preferredCarrier     String?      @map("preferred_carrier")
  preferredNetworkType String?      @map("preferred_network_type")
  maxFee               Int?         @map("max_fee")
  minDataGb            Float?       @map("min_data_gb")
  minVoiceMin          Int?         @map("min_voice_min")
  createdAt            DateTime     @default(now()) @db.Timestamptz
  updatedAt            DateTime     @updatedAt @db.Timestamptz

  @@map("user_demands")
}
